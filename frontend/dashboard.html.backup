<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LogSense - Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        }

        body {
            background-color: #f5f5f5;
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar */
        .sidebar {
            width: 250px;
            background: #1a1a1a;
            color: white;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
        }

        .sidebar-header {
            padding: 24px 20px;
            border-bottom: 1px solid #333;
        }

        .sidebar-header h2 {
            font-size: 20px;
            font-weight: 600;
            letter-spacing: 1px;
            color: white;
        }

        .sidebar-header p {
            font-size: 12px;
            color: #999;
            margin-top: 4px;
        }

        .sidebar-nav {
            flex: 1;
            padding: 20px 0;
        }

        .sidebar-nav a {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: #ccc;
            text-decoration: none;
            transition: all 0.3s;
            font-size: 14px;
        }

        .sidebar-nav a:hover {
            background: #333;
            color: white;
        }

        .sidebar-nav a.active {
            background: #333;
            color: white;
            border-left: 3px solid white;
        }

        .sidebar-nav a i {
            width: 24px;
            font-size: 16px;
            margin-right: 12px;
        }

        .sidebar-footer {
            padding: 20px;
            border-top: 1px solid #333;
        }

        .sidebar-footer a {
            display: flex;
            align-items: center;
            color: #ccc;
            text-decoration: none;
            font-size: 14px;
            padding: 8px 0;
        }

        .sidebar-footer a:hover {
            color: white;
        }

        .sidebar-footer a i {
            width: 24px;
            margin-right: 12px;
        }

        /* Main Content */
        .main-content {
            flex: 1;
            margin-left: 250px;
            padding: 30px;
        }

        .page-header {
            margin-bottom: 30px;
        }

        .page-header h1 {
            font-size: 24px;
            color: #333;
            font-weight: 500;
        }

        .page-header p {
            color: #666;
            font-size: 14px;
            margin-top: 5px;
        }

        /* Stats Grid */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: white;
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

        .stat-card h3 {
            color: #666;
            font-size: 14px;
            font-weight: 500;
            margin-bottom: 10px;
        }

        .stat-number {
            color: #1a1a1a;
            font-size: 28px;
            font-weight: 600;
            margin-bottom: 5px;
        }

        .stat-subtitle {
            color: #999;
            font-size: 12px;
        }

        /* Two Column Layout */
        .two-column {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 30px;
        }

        .card {
            background: white;
            border-radius: 8px;
            padding: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .card-header h2 {
            color: #333;
            font-size: 16px;
            font-weight: 600;
        }

        .card-header a {
            color: #1a1a1a;
            text-decoration: none;
            font-size: 13px;
            font-weight: 500;
        }

        .card-header a:hover {
            text-decoration: underline;
        }

        /* Fraud Types List */
        .fraud-types {
            list-style: none;
        }

        .fraud-type-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #f0f0f0;
        }

        .fraud-type-item:last-child {
            border-bottom: none;
        }

        .fraud-type-name {
            color: #333;
            font-size: 14px;
        }

        .fraud-type-count {
            background: #f0f0f0;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 12px;
            color: #666;
        }

        .fraud-type-bar {
            width: 100px;
            height: 6px;
            background: #f0f0f0;
            border-radius: 3px;
            overflow: hidden;
        }

        .fraud-type-bar-fill {
            height: 100%;
            background: #1a1a1a;
            border-radius: 3px;
        }

        /* Recent Alerts Table */
        .recent-alerts-table {
            width: 100%;
            border-collapse: collapse;
        }

        .recent-alerts-table th {
            text-align: left;
            padding: 12px;
            color: #666;
            font-size: 12px;
            font-weight: 600;
            border-bottom: 1px solid #f0f0f0;
        }

        .recent-alerts-table td {
            padding: 12px;
            color: #333;
            font-size: 13px;
            border-bottom: 1px solid #f0f0f0;
        }

        .recent-alerts-table tr:hover {
            background: #f9f9f9;
            cursor: pointer;
        }

        .risk-badge {
            padding: 4px 8px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 500;
            display: inline-block;
        }

        .risk-critical {
            background: #fee;
            color: #c00;
        }

        .risk-high {
            background: #fff3e0;
            color: #f57c00;
        }

        .risk-medium {
            background: #fff9c4;
            color: #fbc02d;
        }

        .risk-low {
            background: #e8f5e9;
            color: #2e7d32;
        }

        .loading {
            text-align: center;
            padding: 40px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <h2>LOGSENSE</h2>
            <p>Fraud Detection</p>
        </div>

        <div class="sidebar-nav">
            <a href="/dashboard" class="active">
                <i>DS</i> Dashboard
            </a>
            <a href="/alerts">
                <i>AL</i> Alerts
            </a>
            <a href="/analyze">
                <i>AN</i> Analyze
            </a>
            <a href="/settings">
                <i>ST</i> Settings
            </a>
        </div>

        <div class="sidebar-footer">
            <a href="#" onclick="logout()">
                <i>LO</i> Logout
            </a>
        </div>
    </div>

    <div class="main-content">
        <div class="page-header">
            <h1>Dashboard</h1>
            <p>Overview of fraud detection activity</p>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <h3>Total Alerts</h3>
                <div class="stat-number" id="totalAlerts">24</div>
                <div class="stat-subtitle">Last 24 hours</div>
            </div>
            <div class="stat-card">
                <h3>Critical</h3>
                <div class="stat-number" id="criticalCount">8</div>
                <div class="stat-subtitle">Requires attention</div>
            </div>
            <div class="stat-card">
                <h3>High Risk</h3>
                <div class="stat-number" id="highCount">12</div>
                <div class="stat-subtitle">Needs review</div>
            </div>
            <div class="stat-card">
                <h3>Fraud Saved</h3>
                <div class="stat-number" id="fraudAmount">KES 1.2M</div>
                <div class="stat-subtitle">Estimated amount</div>
            </div>
        </div>

        <div class="two-column">
            <div class="card">
                <div class="card-header">
                    <h2>Recent Transactions</h2>
                    <a href="/alerts">View all →</a>
                </div>
                <table class="recent-alerts-table">
                    <thead>
                        <tr>
                            <th>User</th>
                            <th>Amount</th>
                            <th>Type</th>
                            <th>Time</th>
                        </tr>
                    </thead>
                    <tbody id="recentTransactionsList">
                        <!-- Transactions will be inserted here -->
                    </tbody>
                </table>
            </div>

            <div class="card">
                <div class="card-header">
                    <h2>Fraud Types Distribution</h2>
                </div>
                <div id="fraudTypesList">
                    <div class="loading">Loading fraud types...</div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h2>Recent Alerts</h2>
                <a href="/alerts">View all →</a>
            </div>
            <table class="recent-alerts-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Fraud Type</th>
                        <th>Amount</th>
                        <th>Risk</th>
                        <th>Time</th>
                    </tr>
                </thead>
                <tbody id="recentAlertsList">
                    <tr>
                        <td colspan="5" class="loading">Loading alerts...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        // Store transactions in memory (will reset on page refresh)
        let recentTransactions = [];

        // Mock data for initial load
        const mockTransactions = [
            { user: 'John Kamau', amount: 45000, type: 'Transfer', time: '2 min ago' },
            { user: 'Mary Akinyi', amount: 120000, type: 'Transfer', time: '15 min ago' },
            { user: 'Peter Odhiambo', amount: 25000, type: 'Bill Payment', time: '1 hour ago' },
            { user: 'John Kamau', amount: 5000, type: 'Airtime', time: '3 hours ago' },
            { user: 'Mary Akinyi', amount: 35000, type: 'Transfer', time: '5 hours ago' }
        ];

        // Initialize with mock data
        recentTransactions = [...mockTransactions];

        function logout() {
            sessionStorage.removeItem('adminLoggedIn');
            window.location.href = '/login';
        }

        async function fetchDashboardData() {
            try {
                // Fetch alerts for stats and fraud types
                const alertsResponse = await fetch('/api/v2/alerts/recent?limit=50');
                const alerts = await alertsResponse.json();
                
                if (Array.isArray(alerts)) {
                    updateStats(alerts);
                    displayFraudTypes(alerts);
                    displayRecentAlerts(alerts.slice(0, 5));
                }

                // Display recent transactions (mock + real)
                displayRecentTransactions();

            } catch (error) {
                console.error('Error fetching dashboard data:', error);
                // Still show mock data even if API fails
                displayRecentTransactions();
            }
        }

        function updateStats(alerts) {
            const totalAlerts = alerts.length;
            const criticalCount = alerts.filter(a => a.risk_level === 'CRITICAL').length;
            const highCount = alerts.filter(a => a.risk_level === 'HIGH').length;
            
            document.getElementById('totalAlerts').textContent = totalAlerts || 24;
            document.getElementById('criticalCount').textContent = criticalCount || 8;
            document.getElementById('highCount').textContent = highCount || 12;
        }

        function displayRecentTransactions() {
            const tbody = document.getElementById('recentTransactionsList');
            
            if (recentTransactions.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="loading">No transactions</td></tr>';
                return;
            }

            let html = '';
            recentTransactions.slice(0, 5).forEach(tx => {
                html += `
                    <tr>
                        <td>${tx.user}</td>
                        <td>KES ${tx.amount.toLocaleString()}</td>
                        <td>${tx.type}</td>
                        <td>${tx.time}</td>
                    </tr>
                `;
            });
            
            tbody.innerHTML = html;
        }

        function displayFraudTypes(alerts) {
            const container = document.getElementById('fraudTypesList');
            
            if (!alerts || alerts.length === 0) {
                container.innerHTML = '<div class="loading">No fraud data</div>';
                return;
            }

            const counts = {};
            alerts.forEach(alert => {
                const type = alert.fraud_name || alert.fraud_type;
                counts[type] = (counts[type] || 0) + 1;
            });

            const total = alerts.length;
            let html = '<ul class="fraud-types">';

            Object.entries(counts).slice(0, 5).forEach(([type, count]) => {
                const percentage = Math.round((count / total) * 100);
                html += `
                    <li class="fraud-type-item">
                        <span class="fraud-type-name">${type}</span>
                        <div style="display: flex; align-items: center; gap: 15px;">
                            <span class="fraud-type-count">${count}</span>
                            <div class="fraud-type-bar">
                                <div class="fraud-type-bar-fill" style="width: ${percentage}%;"></div>
                            </div>
                        </div>
                    </li>
                `;
            });
            html += '</ul>';
            
            container.innerHTML = html;
        }

        function displayRecentAlerts(alerts) {
            const tbody = document.getElementById('recentAlertsList');
            
            if (!alerts || alerts.length === 0) {
                tbody.innerHTML = '<tr><td colspan="5" class="loading">No recent alerts</td></tr>';
                return;
            }

            let html = '';
            alerts.forEach(alert => {
                const riskClass = alert.risk_level === 'CRITICAL' ? 'risk-critical' : 
                                 alert.risk_level === 'HIGH' ? 'risk-high' : 'risk-medium';
                const time = new Date(alert.timestamp).toLocaleTimeString();
                
                html += `
                    <tr onclick="viewAlert(${alert.alert_id})" style="cursor: pointer;">
                        <td>${alert.user_name || alert.user_id}</td>
                        <td>${alert.fraud_name}</td>
                        <td>KES ${(alert.amount || 0).toLocaleString()}</td>
                        <td><span class="risk-badge ${riskClass}">${alert.risk_level}</span></td>
                        <td>${time}</td>
                    </tr>
                `;
            });
            
            tbody.innerHTML = html;
        }

        function viewAlert(alertId) {
            window.location.href = `/analyze?id=${alertId}`;
        }

        // Function to add a new transaction (called from mobile app)
        window.addTransaction = function(transaction) {
            recentTransactions.unshift({
                user: transaction.user,
                amount: transaction.amount,
                type: transaction.type,
                time: 'Just now'
            });
            displayRecentTransactions();
        };

        window.onload = function() {
            if (sessionStorage.getItem('adminLoggedIn') !== 'true') {
                window.location.href = '/login';
                return;
            }
            fetchDashboardData();
            setInterval(fetchDashboardData, 30000);
        };
    </script>
</body>
</html>
